<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Iris.Desktop.ViewModels"
             xmlns:converters="using:Iris.Desktop.Converters"
             xmlns:models="using:Iris.Desktop.Models"
             x:Class="Iris.Desktop.Controls.Avatar.AvatarPanel"
             x:DataType="vm:AvatarViewModel">

  <UserControl.Resources>
    <converters:StateEqualityConverter x:Key="StateEqualityConverter" />
    <converters:NotHiddenConverter x:Key="NotHiddenConverter" />
    <converters:AvatarSizeToPixelConverter x:Key="SizeConverter" />
    <converters:AvatarPositionToAlignmentConverter x:Key="PositionToHorizontalAlignment" />
    <converters:AvatarPositionToAlignmentConverter x:Key="PositionToVerticalAlignment" />
    <models:AvatarState x:Key="IdleState">Idle</models:AvatarState>
    <models:AvatarState x:Key="ThinkingState">Thinking</models:AvatarState>
    <models:AvatarState x:Key="SpeakingState">Speaking</models:AvatarState>
    <models:AvatarState x:Key="SuccessState">Success</models:AvatarState>
    <models:AvatarState x:Key="ErrorState">Error</models:AvatarState>
  </UserControl.Resources>

  <!--
    Iris Avatar — Premium UI v1 ring indicator (FR-015).
    Plan: docs/plans/2026-05-03-premium-ui-overhaul-v1.plan.md (Phase 6)
    Ring visuals are driven entirely by XAML Style Selectors and Animations;
    no C# timers introduced for the ring (existing AvatarViewModel timer for
    Success state is preserved).
  -->
  <Grid IsVisible="{Binding State, Converter={StaticResource NotHiddenConverter}}"
        Width="{Binding Size, Converter={StaticResource SizeConverter}}"
        Height="{Binding Size, Converter={StaticResource SizeConverter}}">

    <!-- Idle image -->
    <Image Source="/Assets/Avatars/idle.png"
           IsVisible="{Binding State,
               Converter={StaticResource StateEqualityConverter},
               ConverterParameter={StaticResource IdleState}}" />
    <!-- Thinking image -->
    <Image Source="/Assets/Avatars/thinking.png"
           IsVisible="{Binding State,
               Converter={StaticResource StateEqualityConverter},
               ConverterParameter={StaticResource ThinkingState}}" />
    <!-- Speaking image (reserved for Voice v1) -->
    <Image Source="/Assets/Avatars/speaking.png"
           IsVisible="{Binding State,
               Converter={StaticResource StateEqualityConverter},
               ConverterParameter={StaticResource SpeakingState}}" />
    <!-- Success image -->
    <Image Source="/Assets/Avatars/success.png"
           IsVisible="{Binding State,
               Converter={StaticResource StateEqualityConverter},
               ConverterParameter={StaticResource SuccessState}}" />
    <!-- Error image -->
    <Image Source="/Assets/Avatars/error.png"
           IsVisible="{Binding State,
               Converter={StaticResource StateEqualityConverter},
               ConverterParameter={StaticResource ErrorState}}" />

    <!-- Fallback visual when images are unavailable -->
    <Panel x:Name="FallbackPanel"
           IsVisible="True">
      <Panel.Styles>
        <Style Selector="Ellipse.fallbackCircle">
          <Setter Property="Fill" Value="#404040" />
          <Setter Property="Stroke" Value="#808080" />
          <Setter Property="StrokeThickness" Value="2" />
          <Setter Property="Width" Value="60" />
          <Setter Property="Height" Value="60" />
          <Setter Property="HorizontalAlignment" Value="Center" />
          <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.fallbackText">
          <Setter Property="Foreground" Value="#C0C0C0" />
          <Setter Property="FontSize" Value="10" />
          <Setter Property="HorizontalAlignment" Value="Center" />
          <Setter Property="VerticalAlignment" Value="Center" />
          <Setter Property="Text" Value="Iris" />
        </Style>
      </Panel.Styles>
      <Ellipse Classes="fallbackCircle" />
      <TextBlock Classes="fallbackText" />
    </Panel>

    <!-- Ring indicator (FR-015) -->
    <Ellipse x:Name="StateRing"
             StrokeThickness="2"
             Fill="Transparent"
             IsHitTestVisible="False"
             Classes.idle="{Binding State,
                 Converter={StaticResource StateEqualityConverter},
                 ConverterParameter={StaticResource IdleState}}"
             Classes.thinking="{Binding State,
                 Converter={StaticResource StateEqualityConverter},
                 ConverterParameter={StaticResource ThinkingState}}"
             Classes.success="{Binding State,
                 Converter={StaticResource StateEqualityConverter},
                 ConverterParameter={StaticResource SuccessState}}"
             Classes.error="{Binding State,
                 Converter={StaticResource StateEqualityConverter},
                 ConverterParameter={StaticResource ErrorState}}">
      <Ellipse.Styles>
        <Style Selector="Ellipse#StateRing.idle">
          <Setter Property="Stroke" Value="{StaticResource Iris.AccentPrimary}" />
          <Setter Property="Opacity" Value="0.3" />
        </Style>
        <Style Selector="Ellipse#StateRing.thinking">
          <Setter Property="Stroke" Value="{StaticResource Iris.AccentPrimary}" />
          <Setter Property="Opacity" Value="1.0" />
          <Style.Animations>
            <Animation Duration="0:0:1.5"
                       IterationCount="INFINITE"
                       PlaybackDirection="Alternate">
              <KeyFrame Cue="0%">
                <Setter Property="Opacity" Value="0.4" />
              </KeyFrame>
              <KeyFrame Cue="100%">
                <Setter Property="Opacity" Value="1.0" />
              </KeyFrame>
            </Animation>
          </Style.Animations>
        </Style>
        <Style Selector="Ellipse#StateRing.success">
          <Setter Property="Stroke" Value="{StaticResource Iris.AccentSecondary}" />
          <Setter Property="Opacity" Value="1.0" />
        </Style>
        <Style Selector="Ellipse#StateRing.error">
          <Setter Property="Stroke" Value="{StaticResource Iris.Error}" />
          <Setter Property="Opacity" Value="0.6" />
        </Style>
      </Ellipse.Styles>
    </Ellipse>
  </Grid>
</UserControl>
