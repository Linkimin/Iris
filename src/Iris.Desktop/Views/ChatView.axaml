<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Iris.Desktop.ViewModels"
             xmlns:models="using:Iris.Desktop.Models"
             xmlns:chat="using:Iris.Desktop.Controls"
             x:Class="Iris.Desktop.Views.ChatView"
             x:DataType="vm:ChatViewModel">
  <!--
    Iris ChatView — Premium UI v1 (FR-001, FR-012, FR-013, FR-014, FR-019).
    All colors via {StaticResource Iris.*}; no hex literals.
    Plan: docs/plans/2026-05-03-premium-ui-overhaul-v1.plan.md (Phase 3)
  -->
  <Grid RowDefinitions="Auto,*,Auto"
        RowSpacing="12"
        Margin="20"
        Background="Transparent">

    <!-- Thought Log placeholder (FR-012) -->
    <TextBlock Grid.Row="0"
               Text="[core] thinking…"
               FontFamily="{StaticResource Iris.FontFamily.Mono}"
               FontSize="{StaticResource Iris.FontSize.Mono}"
               Foreground="{StaticResource Iris.TextLog}"
               IsVisible="{Binding IsSending}"
               HorizontalAlignment="Left" />

    <!-- Messages list -->
    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <ItemsControl ItemsSource="{Binding Messages}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:ChatMessageViewModelItem">
            <chat:ChatMessageBubble Margin="0,0,0,10" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Status + input region -->
    <Grid Grid.Row="2"
          RowDefinitions="Auto,Auto"
          RowSpacing="8">
      <TextBlock Grid.Row="0"
                 Text="{Binding ErrorMessage}"
                 IsVisible="{Binding HasError}"
                 Foreground="{StaticResource Iris.Error}"
                 FontFamily="{StaticResource Iris.FontFamily.Ui}"
                 FontSize="{StaticResource Iris.FontSize.Body}"
                 TextWrapping="Wrap" />

      <Grid Grid.Row="1"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="8">
        <TextBox x:Name="InputTextBox"
                 Grid.Column="0"
                 Text="{Binding InputText, Mode=TwoWay}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="48"
                 MaxHeight="160"
                 IsEnabled="{Binding CanEditInput}"
                 PlaceholderText="Message Iris (Enter to send, Shift+Enter for new line)"
                 Background="Transparent"
                 BorderBrush="{StaticResource Iris.AccentPrimary}"
                 BorderThickness="0,0,0,1"
                 CornerRadius="0"
                 Padding="4,8"
                 Foreground="{StaticResource Iris.TextPrimary}"
                 FontFamily="{StaticResource Iris.FontFamily.Ui}"
                 FontSize="{StaticResource Iris.FontSize.Body}">
          <TextBox.KeyBindings>
            <KeyBinding Gesture="Enter"
                        Command="{Binding SendMessageCommand}" />
          </TextBox.KeyBindings>
        </TextBox>

        <Button Grid.Column="1"
                MinWidth="96"
                VerticalAlignment="Stretch"
                Background="{StaticResource Iris.AccentPrimary}"
                Foreground="{StaticResource Iris.TextPrimary}"
                FontFamily="{StaticResource Iris.FontFamily.Ui}"
                FontSize="{StaticResource Iris.FontSize.Body}"
                FontWeight="SemiBold"
                Command="{Binding SendMessageCommand}">
          Send
        </Button>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
