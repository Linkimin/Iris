<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Iris.Desktop.ViewModels"
             xmlns:models="using:Iris.Desktop.Models"
             xmlns:chat="using:Iris.Desktop.Controls"
             x:Class="Iris.Desktop.Views.ChatView"
             x:DataType="vm:ChatViewModel">
  <Grid RowDefinitions="Auto,*,Auto"
        RowSpacing="16"
        Margin="20"
        Background="#101216">
    <StackPanel Grid.Row="0"
                Spacing="2">
      <TextBlock Text="Iris"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Foreground="#F2F4F8" />
      <TextBlock Text="Local chat"
                 FontSize="13"
                 Foreground="#AAB2C0" />
    </StackPanel>

    <Border Grid.Row="1"
            BorderBrush="#2A3140"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Background="#151922">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Messages}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:ChatMessageViewModelItem">
              <chat:ChatMessageBubble Margin="0,0,0,10" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <Grid Grid.Row="2"
          RowDefinitions="Auto,Auto,Auto"
          RowSpacing="8">
      <TextBlock Grid.Row="0"
                 Text="{Binding ErrorMessage}"
                 IsVisible="{Binding HasError}"
                 Foreground="#F08A8A"
                 TextWrapping="Wrap" />

      <TextBlock Grid.Row="1"
                 Text="Thinking..."
                 IsVisible="{Binding IsSending}"
                 Foreground="#AAB2C0" />

      <Grid Grid.Row="2"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="8">
        <TextBox x:Name="InputTextBox"
                 Grid.Column="0"
                 Text="{Binding InputText, Mode=TwoWay}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="48"
                 MaxHeight="160"
                 IsEnabled="{Binding CanEditInput}"
                 PlaceholderText="Message Iris (Enter to send, Shift+Enter for new line)">
          <TextBox.KeyBindings>
            <KeyBinding Gesture="Enter"
                        Command="{Binding SendMessageCommand}" />
          </TextBox.KeyBindings>
        </TextBox>

        <Button Grid.Column="1"
                MinWidth="96"
                VerticalAlignment="Stretch"
                Background="#3B82F6"
                Foreground="#F2F4F8"
                FontWeight="SemiBold"
                Command="{Binding SendMessageCommand}">
          Send
        </Button>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
