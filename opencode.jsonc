
{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "planner",

  "model": "Tokenator/claude-opus-4-7",
  "small_model": "Tokenator/claude-haiku-4-5",

  "disabled_providers": ["openai"],

  "snapshot": true,

  "share": "disabled",
  "autoupdate": "notify",

  "instructions": [
    ".opencode/rules/workflow.md",
    ".opencode/rules/iris-architecture.md",
    ".opencode/rules/no-shortcuts.md",
    ".opencode/rules/memory.md",
    ".opencode/rules/verification.md",
    ".opencode/rules/dotnet.md",
    ".opencode/rules/security.md",
    ".opencode/rules/review-audit.md"
  ],

  "watcher": {
    "ignore": [
      ".git/**",
      ".vs/**",
      ".idea/**",
      ".vscode/**",
      "bin/**",
      "obj/**",
      "node_modules/**",
      "dist/**",
      "coverage/**",
      ".pytest_cache/**",
      "__pycache__/**",
      "*.user",
      "*.suo",
      "*.log"
    ]
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },

  "provider": {
    "Tokenator": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Tokenator",
      "options": {
        "baseURL": "https://api.tokenator.cloud/v1",
        "apiKey": "{env:TOKENATOR_API_KEY}"
      },
      "models": {
        "gpt-5.5": {
          "name": "gpt-5.5",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          },
          "options": {
            "include": [
              "reasoning.encrypted_content"
            ]
          }
        },
        "claude-opus-4-7": {
          "name": "claude-opus-4-7",
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "variants": {
            "high": {},
            "medium": {},
            "low": {}
          }
        },
        "gemini-3.1-pro-preview": {
          "name": "gemini-3.1-pro-preview",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "attachment": true,
          "reasoning": true,
          "tool_call": true
        },
        "claude-sonnet-4-6": {
          "name": "claude-sonnet-4-6",
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "attachment": true,
          "reasoning": true,
          "tool_call": true
        },
        "claude-opus-4-6": {
          "name": "claude-opus-4-6",
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "variants": {
            "high": {},
            "medium": {},
            "low": {}
          }
        },
        "claude-haiku-4-5": {
          "name": "claude-haiku-4-5",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "attachment": true,
          "reasoning": true,
          "tool_call": true
        }
      }
    }
  },

  "permission": {
    "*": "ask",

    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/secrets.json": "deny",
      "**/appsettings.Production.json": "deny",
      "**/appsettings.Development.json": "ask",
      "**/id_rsa": "deny",
      "**/id_ed25519": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.pfx": "deny",
      "**/*.p12": "deny"
    },

    "grep": "allow",
    "glob": "allow",
    "lsp": "allow",

    "edit": {
      "*": "ask",

      "src/**": "ask",
      "tests/**": "ask",
      "docs/**": "ask",
      ".agents/**": "ask",
      ".opencode/**": "ask",
      "AGENTS.md": "ask",
      "opencode.jsonc": "ask",

      ".git/**": "deny",
      "bin/**": "deny",
      "obj/**": "deny",
      "node_modules/**": "deny",
      "dist/**": "deny",
      "coverage/**": "deny",

      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/secrets.json": "deny",
      "**/appsettings.Production.json": "deny",
      "**/id_rsa": "deny",
      "**/id_ed25519": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.pfx": "deny",
      "**/*.p12": "deny",

      "**/*.sln": "ask",
      "**/*.slnx": "ask",
      "**/*.csproj": "ask",
      "**/Migrations/**": "ask"
    },

    "bash": {
      "*": "ask",

      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",

      "rg*": "allow",
      "find*": "allow",
      "ls*": "allow",
      "dir*": "allow",
      "cat*": "allow",
      "type*": "allow",

      "dotnet build*": "allow",
      "dotnet test*": "allow",
      "dotnet list*": "allow",
      "dotnet restore*": "ask",
      "dotnet format --verify-no-changes*": "allow",
      "dotnet format*": "ask",

      "git commit*": "ask",
      "git push*": "deny",
      "git clean*": "deny",
      "git reset --hard*": "deny",
      "rm -rf*": "deny",
      "del *": "deny",
      "rmdir *": "deny",
      "Remove-Item*": "deny",
      "docker system prune*": "deny",
      "docker compose down*": "ask"
    },

    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "external_directory": "ask",
    "doom_loop": "ask"
  },

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  }
}

